# ─── Entorno ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de Datos (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgres://usuario:password@localhost:5432/archivistica_db

# ─── Supabase (opcional — alternativa a PostgreSQL directo) ───────
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_KEY=eyJ...

# ─── Autenticación JWT ────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_de_al_menos_32_chars
JWT_EXPIRES_IN=8h

# ─── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Storage (archivos digitalizados) ────────────────────────────
STORAGE_BUCKET=expedientes-digitalizados
STORAGE_PATH=./storage/uploads
